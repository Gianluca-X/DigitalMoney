# -------------------------------
# PostgreSQL (común para todos los servicios)
# -------------------------------
DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=digitalmoney_db
DB_USER=digitalmoney_user
DB_PASSWORD=super_secure_password

# -------------------------------
# JWT e Internal Token
# -------------------------------
JWT_SECRET=mySuperUltraSecretKeyForJWTGeneration123456!
INTERNAL_TOKEN=super_internal_token_very_secure

# -------------------------------
# Mail (si alguno de tus servicios envía emails)
# -------------------------------
MAIL_USER=moneydigitaldh@gmail.com
MAIL_PASSWORD=malrmttkridclkrr

# -------------------------------
# URLs internas entre servicios (para Feign Clients)
# -------------------------------
# Desde user-service hacia account-service y auth-service
ACCOUNTS_SERVICE_URL=http://account-service:8084
AUTH_SERVICE_URL=http://auth-service:8082

# Desde account-service hacia otros servicios (si aplica)
USER_SERVICE_URL=http://user-service:8080
AUTH_SERVICE_URL=http://auth-service:8082

# Desde auth-service hacia otros servicios (si aplica)
USER_SERVICE_URL=http://user-service:8080
ACCOUNTS_SERVICE_URL=http://account-service:8084

# -------------------------------
# Spring Profiles
# -------------------------------
SPRING_PROFILES_ACTIVE=prod

# -------------------------------
# Puertos (Render los asigna dinámicamente)
# -------------------------------
PORT=8080 # puedes sobrescribir con ${PORT} en application.yml de cada servicio
